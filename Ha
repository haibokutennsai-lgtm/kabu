@tasks.loop(hours=6)
async def fetch_news():
    feed = feedparser.parse("https://feeds.finance.yahoo.co.jp/rss/pc/main.xml")
    news_text = ""
    for entry in feed.entries[:5]:
        news_text += f"{entry.title}\n{entry.link}\n\n"
    for guild in bot.guilds:
        for channel in guild.text_channels:
            if channel.name=="finance-news":
                await channel.send(news_text)

