# ---------------- 株価・資産取得 ----------------
def get_price(code, period="2y"):
    code_lower = code.lower()
    if code_lower in ['btc','eth','doge','xrp','usd','eur','gold']:
        mapping = {'btc':'BTC-USD','eth':'ETH-USD','doge':'DOGE-USD','xrp':'XRP-USD','usd':'DX-Y.NY','eur':'EURUSD=X','gold':'GC=F'}
        code_yf = mapping[code_lower]
    else:
        code_yf = code
    stock = yf.Ticker(code_yf)
    data = stock.history(period=period)
    price = data["Close"].iloc[-1]
    prev = data["Close"].iloc[-2] if len(data)>1 else price
    change = price-prev
    pct_change = (change/prev*100) if prev!=0 else 0
    volatility = data["Close"].pct_change().std()*100
    return price, change, pct_change, volatility, data, code_yf

