# ---------------- チャート生成 ----------------
def create_full_chart(data, code, days=60):
    if data is None or data.empty:
        return None
    data = data[-days:]
    data['MA5'] = data['Close'].rolling(5).mean()
    data['MA20'] = data['Close'].rolling(20).mean()
    data['Upper'] = data['MA20'] + 2*data['Close'].rolling(20).std()
    data['Lower'] = data['MA20'] - 2*data['Close'].rolling(20).std()
    fig = plt.figure(figsize=(10,6))
    plt.plot(data.index, data['Close'], label='Close')
    plt.plot(data.index, data['MA5'], label='MA5')
    plt.plot(data.index, data['MA20'], label='MA20')
    plt.fill_between(data.index, data['Upper'], data['Lower'], alpha=0.2)
    plt.title(f"{code} チャート")
    plt.legend()
    filename = f"chart_{code}_{datetime.datetime.now().strftime('%Y%m%d%H%M%S')}.png"
    plt.savefig(filename)
    plt.close()
    return filename

@bot.command()
async def チャート(ctx, code):
    price, change, pct, vol, data, code_yf = get_price(code, period="60d")
    if price is None:
        await ctx.send("チャート取得に失敗しました")
        return
    filename = create_full_chart(data, code_yf)
    if filename:
        await ctx.send(file=discord.File(filename))
        os.remove(filename)

# ---------------- PDF生成関数 ----------------
def create_pdf(user_id, codes):
    pdf = FPDF()
    pdf.set_auto_page_break(auto=True, margin=15)
    files = []
    for code in codes:
        price, change, pct, vol, data, code_yf = get_price(code)
        if price is None:
            continue
        filename = create_full_chart(data, code_yf)
        if filename:
            files.append(filename)
            pdf.add_page()
            pdf.set_font("Arial","B",16)
            pdf.cell(0,10,f"{code} チャート", ln=1)
            pdf.image(filename, x=10, y=30, w=190)
    outname = f"portfolio_{user_id}_{datetime.datetime.now().strftime('%Y%m%d%H%M%S')}.pdf"
    pdf.output(outname)
    for f in files:
        os.remove(f)
    return outname

