async def 株(ctx, code):
    code = code.strip().upper()
    if not code.endswith(".T"):
        await ctx.send("日本株は `.T` を付けてください（例:7203.T）")
        return
    price, change, pct, vol, data, _ = get_price(code, period="2d")
